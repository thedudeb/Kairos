# --- Required to run the backend at all -------------------------------------

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/recruitment

# Redis (queue + cache)
REDIS_URL=redis://localhost:6379/0

# Shared with frontend Auth.js — must be the same value in both places
AUTH_SECRET=replace-with-openssl-rand-base64-32

# Shared with frontend for the server-to-server user-sync call
INTERNAL_API_KEY=replace-with-openssl-rand-hex-32

# First admin bootstrap — when this email signs in via Google OAuth on the
# frontend, the user-sync endpoint creates them with role=admin
INITIAL_ADMIN_EMAIL=you@example.com

# CORS — the public origin of the Next.js frontend
FRONTEND_ORIGIN=http://localhost:3000

# --- Required from Day 3 (resume upload + email) ----------------------------

# Google Cloud Storage — bucket where resumes (and any uploaded custom-field
# files) are stored. Locally you can leave this blank and the upload code path
# will short-circuit to a local /tmp dir for dev.
GCS_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=

# Resend (email)
RESEND_API_KEY=
EMAIL_FROM=Recruiting <hello@example.com>

# --- Required from Day 4 (resume parsing) -----------------------------------

# Gemini — used by the worker to extract structured resume data
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
